{
  "name": "clinical-mdr",
  "version": "1.0.0",
  "private": true,
  "description": "Clinical MDR Platform - CDISC/SDTM/ADaM standards management, TFL drag-and-drop rendering, and PR approval workflow",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter skyroc-admin dev",
    "build": "pnpm --filter skyroc-admin build",
    "typecheck": "pnpm --filter skyroc-admin typecheck",
    "e2e": "pnpm --filter skyroc-admin e2e",
    "lint": "pnpm --filter skyroc-admin lint",
    "lint-staged": "cd frontend && pnpm lint-staged",
    "sa": "cd frontend && pnpm sa"
  },
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8.7.0"
  },
  "packageManager": "pnpm@10.4.1"
}
