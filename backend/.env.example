# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@127.0.0.1:15432/clinical_mdr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=clinical_mdr

# Security - CRITICAL: Set these values in production!
# Generate a secure SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Environment
ENVIRONMENT=development

# Default Admin Credentials (for seed data only)
# IMPORTANT: Change these after initial setup in production!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@pharma.com

# CDISC Library API (optional)
CDISC_LIBRARY_API_KEY=
CDISC_API_BASE_URL=https://library.cdisc.org/api